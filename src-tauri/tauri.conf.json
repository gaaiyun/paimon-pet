{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PaimonPet",
  "version": "0.1.0",
  "identifier": "com.paimonpet.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "pet",
        "title": "PaimonPet",
        "width": 340,
        "height": 560,
        "minWidth": 280,
        "minHeight": 400,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
